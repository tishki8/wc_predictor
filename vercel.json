{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/server.py": {
      "maxDuration": 30,
      "includeFiles": "public/**",
      "excludeFiles": "{data/raw/**,*.ipynb,.ipynb_checkpoints/**}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/app/server.py" }
  ]
}