{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/server.py": {
      "maxDuration": 30,
      "excludeFiles": "{data/raw/**,*.ipynb,.ipynb_checkpoints/**}"
    }
  },
  "routes": [
    { "src": "/$", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/app/server.py" }
  ]
}